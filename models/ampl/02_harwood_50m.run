# Run script for Harwood $50M instance
# Usage: ampl 02_harwood_50m.run
# Expected result: net benefit $6,159,517 (matches Harwood Table 4)

reset;
model 02_harwood.mod;
data 02_harwood_50m.dat;

option solver cplex;
option cplex_options 'mipdisplay=2';

solve;

display NetBenefit;
display sum {i in PROJECTS, j in ALTERNATIVES[i]} Cost[i,j] * x[i,j];
display {i in PROJECTS, j in ALTERNATIVES[i]: x[i,j] > 0.5} x[i,j];
