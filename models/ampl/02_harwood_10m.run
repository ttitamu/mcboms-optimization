# Run script for Harwood $10M instance
# Usage: ampl 02_harwood_10m.run
# Expected result: net benefit $4,931,520 (~5.5% above Harwood's published value;
# divergence documented in Chapter 2 Section 2.7.3)

reset;
model 02_harwood.mod;
data 02_harwood_10m.dat;

option solver cplex;
option cplex_options 'mipdisplay=2';

solve;

display NetBenefit;
display sum {i in PROJECTS, j in ALTERNATIVES[i]} Cost[i,j] * x[i,j];
display {i in PROJECTS, j in ALTERNATIVES[i]: x[i,j] > 0.5} x[i,j];
